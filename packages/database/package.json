{
  "name": "@repo/db",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');function r(d){fs.readdirSync(d).forEach(f=>{const fp=p.join(d,f);fs.statSync(fp).isDirectory()?r(fp):fs.writeFileSync(fp,fs.readFileSync(fp,'utf8').replace(/\\.ts\"/g,'.js\"'),'utf8')});}r('dist')\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:init": "prisma migrate dev --name init",
    "db:deploy": "prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "prisma": "^7.8.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  }
}
